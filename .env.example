# =====================================================================
# SEO Agent Bot — Environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` (it is gitignored).
# =====================================================================

# ---------------------------------------------------------------------
# Google AI Studio (Gemini)
# ---------------------------------------------------------------------
# Generate at https://aistudio.google.com/app/apikey
# Make sure the key is bound to a project with a $5–10 hard budget cap.
GOOGLE_GENERATIVE_AI_API_KEY=

# ---------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------
# Project URL and anon key from https://supabase.com/dashboard → Project
# Settings → API. The service-role key is also there — KEEP IT SECRET,
# it bypasses RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------
# Telegram (publish target)
# ---------------------------------------------------------------------
# 1. Create a bot via @BotFather → copy the token below.
# 2. Create a channel (public or private) in Telegram.
# 3. Add the bot as administrator with "Post Messages" permission.
# 4. CHANNEL_ID:
#      - public channel: "@your_channel"
#      - private channel: "-100xxxxxxxxxx" (numeric, with the -100 prefix)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ---------------------------------------------------------------------
# Google Search Console (used by the weekly evaluator)
# ---------------------------------------------------------------------
# Service account JSON, base64-encoded. Optional for the smoke test —
# the evaluator will skip GSC reads if these are missing.
# Generate via: cat sa.json | base64 | tr -d '\n'
GSC_SERVICE_ACCOUNT_JSON_B64=
# Site URL exactly as registered in Search Console (e.g. "https://yoursite.com/").
GSC_SITE_URL=

# ---------------------------------------------------------------------
# Cron protection
# ---------------------------------------------------------------------
# Vercel Cron will send `Authorization: Bearer ${CRON_SECRET}` automatically
# when this env var exists. Pick a long random string (e.g. `openssl rand -hex 32`).
CRON_SECRET=

# ---------------------------------------------------------------------
# Guardrails (optional overrides)
# ---------------------------------------------------------------------
# Daily LLM-spend cap in USD. Defaults to $1.00 if unset.
# The orchestrator refuses to start when today's spend reaches this cap.
DAILY_BUDGET_USD=1.00
